<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/overview_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO -->
            <FrameLayout
                android:id="@+id/hero_container"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/hero_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#111111"
                    android:contentDescription="Featured movie backdrop"
                    tools:src="@tools:sample/backgrounds/scenic" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/scrim_bottom" />

                <TextView
                    android:id="@+id/hero_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:padding="20dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    tools:text="War Machine" />
            </FrameLayout>

            <!-- ROW 1 — Popular (other 3 rows are identical except id + label) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="@string/popular"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/popular_row"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:clipToPadding="false"
                tools:listitem="@layout/grid_view_item" />

            <!-- ROW 1 — Popular (other 3 rows are identical except id + label) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="@string/top_rated"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/top_rated_row"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:clipToPadding="false"
                tools:listitem="@layout/grid_view_item" />

            <!-- ROW 1 — Popular (other 3 rows are identical except id + label) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="@string/now_playing"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/now_playing_row"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:clipToPadding="false"
                tools:listitem="@layout/grid_view_item" />

            <!-- ROW 1 — Popular (other 3 rows are identical except id + label) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="@string/upcoming"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/upcoming_row"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:clipToPadding="false"
                tools:listitem="@layout/grid_view_item" />

            <!-- Repeat 3 more times for top_rated_row, now_playing_row, upcoming_row → see actual file -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Status overlay (LOADING / ERROR) -->
    <LinearLayout
        android:id="@+id/status_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <ProgressBar
            android:id="@+id/loading_spinner"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="#E50914"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/error_image"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_connection_error"
            android:contentDescription="Connection error"
            android:visibility="gone" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>